# Copy to sentinelops.env and fill in. sentinelops.env is gitignored.

# Hugging Face (for model + dataset push, license-gated models)
HF_TOKEN=

# Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=sentinelops
WANDB_ENTITY=

# Kaggle (for triggering notebooks from Airflow in Week 5)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Qdrant — local uses localdev, cloud gets real key in Week 3
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=localdev

# Groq (LLM-as-judge in Week 3/4)
GROQ_API_KEY=

# Modal (vLLM serving in Week 4)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# GitHub (for scraping status incidents — optional, higher rate limit)
GITHUB_TOKEN=